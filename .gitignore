*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.nox/
.tox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Virtual environments
/.venv/
/venv/
/env/
/ENV/
.python-version

# Build and packaging outputs
/build/
/dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Node / npm outputs for future TS tooling
/node_modules/
/npm-debug.log*
/yarn-debug.log*
/yarn-error.log*
/pnpm-debug.log*
/.npm/
/coverage/

# Local environment, credentials, and secrets
.env
.env.*
!.env.example
!.env.sample
.envrc
/.direnv/
*.pem
*.key
*.crt
*.p12
/secrets/

# Generated Idea2Repo outputs
/generated_repos/
/outputs/
/runs/
/.idea2repo/

# Logs, reports, and local databases
*.log
/logs/
*.sqlite
*.sqlite3
*.db
*.tmp

# OS and editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Large research artifacts kept out of git by default
/data/raw/
/data/processed/
/results/
/artifacts/
/checkpoints/
/models/
/wandb/
/mlruns/
*.ckpt
*.pt
*.pth
*.safetensors
