{
  "profile_id": "ieee-conference",
  "venue_key": "ieee-sp",
  "venue_name": "IEEE Conference",
  "aliases": ["IEEE S&P", "S&P", "HPCA", "MICRO"],
  "domain": "systems",
  "ccf_rank": "A",
  "template_family": "ieee",
  "publisher_hint": "IEEE",
  "official_template_url": "https://www.ieee.org/conferences/publishing/templates.html",
  "official_template_version": "IEEEtran",
  "official_template_verified_at": null,
  "review_modes": ["anonymous", "non_anonymous", "camera_ready"],
  "default_review_mode": "anonymous",
  "latex": {
    "documentclass": "IEEEtran",
    "documentclass_options": ["conference"],
    "usepackages": [],
    "bibliography_style": "IEEEtran",
    "citation_style": "numeric",
    "main_tex_template": "ieee-conference/main.tex",
    "section_template_dir": "common/sections",
    "compile_engine": "pdflatex"
  },
  "paper_rules": {
    "columns": 2,
    "font_size": "10pt",
    "main_page_limit": null,
    "references_count_toward_limit": null,
    "appendix_allowed": true,
    "supplement_allowed": true,
    "checklist_required": false,
    "anonymity_required": true
  },
  "required_files": ["paper/main.tex", "paper/macros.tex", "paper/references.bib"],
  "optional_files": ["paper/appendix/appendix.tex"],
  "forbidden_patterns": ["\\\\author\\{[^}]+\\}", "github.com/.+"],
  "notes": ["Use IEEEtran conference class and numeric citations."]
}
