{
  "profile_id": "acl-anthology",
  "venue_key": "acl",
  "venue_name": "ACL Anthology Venue",
  "aliases": ["ACL", "EMNLP", "NAACL"],
  "domain": "ai_llm_agent",
  "ccf_rank": "A",
  "template_family": "acl",
  "publisher_hint": "ACL Anthology",
  "official_template_url": "https://acl-org.github.io/ACLPUB/",
  "official_template_version": "acl_latex",
  "official_template_verified_at": null,
  "review_modes": ["anonymous", "non_anonymous", "camera_ready"],
  "default_review_mode": "anonymous",
  "latex": {
    "documentclass": "article",
    "documentclass_options": ["11pt"],
    "usepackages": ["acl"],
    "bibliography_style": "acl_natbib",
    "citation_style": "author_year",
    "main_tex_template": "acl/main.tex",
    "section_template_dir": "common/sections",
    "compile_engine": "pdflatex"
  },
  "paper_rules": {
    "columns": 2,
    "font_size": "11pt",
    "main_page_limit": 8,
    "references_count_toward_limit": false,
    "appendix_allowed": true,
    "supplement_allowed": true,
    "checklist_required": true,
    "anonymity_required": true
  },
  "required_files": ["paper/main.tex", "paper/macros.tex", "paper/references.bib"],
  "optional_files": ["paper/checklist/reproducibility_checklist.tex"],
  "forbidden_patterns": ["\\\\author\\{[^}]+\\}", "github.com/.+"],
  "notes": ["ACL page limits and checklist rules vary by year; verify CFP."]
}
